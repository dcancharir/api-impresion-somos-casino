{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "SqliteConnection": "Data Source=C:\\sqlitedatabase\\terminalimpresion.db"
    },
    "Jobs": {
        "RealizarJobImpresion": true,
        "RealizarJobMigracionImpresos": true,
        "RealizarJobHistorialImpresion": false,
        "IntervaloSegundosJobImpresion": 1, //segundos
        "IntervaloSegundosJobMigracionImpresos": 5,
        "IntervaloSegundosJobHistorialImpresion": 5
    },
    "Configuracion": {
        "UrlSorteosGlobalesAzure": "http://localhost:12345"
    },
    "ServiceBus": {
        "ConnectionString": ""
    },
    "Target": {
        "QueuePrefix": "cuponesImpresion",
        "SedeId": 3,
        "TerminalId": 2
    },
    "Worker": {
        "PollMs": 1000,
        "MaxMessages": 50,
        "ReadMode": "Receive",
        "Complete": true
    }
}
